# --- OpenRouter (OpenAI-compatible) ---
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Models (Claude via OpenRouter; vision-capable) ---
TB_TEXT_MODEL=anthropic/claude-sonnet-4.6
TB_VISION_MODEL=anthropic/claude-sonnet-4.6
TB_JUDGE_MODEL=anthropic/claude-sonnet-4.6

# --- Generation config ---
TB_MCQ_PER_BLOCK=2
TB_FINAL_ASSESSMENT_COUNT=5
TB_PASS_THRESHOLD=7.0
TB_MAX_REFINE_ATTEMPTS=1

# --- LLM toggle: real | mock ---
TB_LLM_MODE=real

# --- Supabase Postgres: REQUIRED. The single persistence backend (no SQLite/local).
#     Holds: LangGraph checkpoints, course memory, cost ledger, run metadata.
#     Copy from Supabase → Project Settings → Database → Connection string → URI
#     (use the Session pooler or Direct connection; URL-encode special chars in the password).
#     Run backend/supabase_schema.sql once in the Supabase SQL editor before first use. ---
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@<host>:5432/postgres
TB_DB_POOL_MAX=10

# --- Cost panel: USD→INR FALLBACK rate. The panel uses a LIVE rate by default;
#     this value is only used if the live FX lookup is unavailable (offline). ---
TB_USD_TO_INR=88

# --- Paths (file artifacts only: input decks, extracted images, drafts, published tutorials) ---
TB_RUNS_DIR=runs

# Optional OpenRouter attribution headers
OPENROUTER_APP_TITLE=Tutorial Builder
OPENROUTER_HTTP_REFERER=http://localhost
