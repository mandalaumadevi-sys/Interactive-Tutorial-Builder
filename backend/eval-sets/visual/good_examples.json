        "reference_file": "waterfall-model-animation.html",
        "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Waterfall Model — Animated</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n<style>\n    :root {\n        --req: #1b5e9c;   /* Requirement Analysis */\n        --des: #6c7fd0;   /* Design */\n        --dev: #1f9bbf;   /* Development */\n        --test: #93bf3f;  /* Testing */\n        --dep: #c33d2e;   /* Deployment */\n        --mnt: #e6a200;   /* Maintenance */\n        --arrow: #ef8f2e; /* connectors */\n        --lblText: #5b6470;\n        --lblBorder: #e3e7ec;\n        --em: #2563eb;    /* bold emphasis words */\n    }\n\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n\n    body {\n        font-family: 'Inter', sans-serif;\n        background: #f8fafc;\n        min-height: 100vh;\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        justify-content: center;\n        padding: 40px 20px;\n        color: #1f2937;\n    }\n\n    .stage-heading { text-align: center; margin-bottom: 6px; }\n    .stage-heading h1 { font-size: 1.6rem; font-weight: 700; color: #1f2937; }\n    .stage-heading p  { font-size: 0.95rem; color: #6b7280; font-style: italic; margin-top: 4px; }\n\n    .stage {\n        width: 100%;\n        max-width: 940px;\n        background: #ffffff;\n        border: 1px solid #eef2f7;\n        border-radius: 16px;\n        box-shadow: 0 8px 30px rgba(15, 23, 42, 0.06);\n        padding: 28px 24px 32px;\n        margin-top: 22px;\n    }\n\n    svg { width: 100%; height: auto; display: block; }\n\n    /* ── BLOCK & LABEL TEXT ── */\n    .blk-t  { fill: #ffffff; font-family: 'Inter', sans-serif; font-weight: 700; font-size: 15px; }\n    .lbl-box { fill: #ffffff; stroke: var(--lblBorder); stroke-width: 1.5; }\n    .lbl-t  { fill: var(--lblText); font-family: 'Inter', sans-serif; font-weight: 500; font-size: 14px; }\n    .lbl-t .em { fill: var(--em); font-weight: 700; }\n\n    .blk rect { filter: drop-shadow(0 2px 3px rgba(0,0,0,0.16)); }\n\n    /* ── REVEAL ANIMATION (blocks + labels) ── */\n    .reveal {\n        opacity: 0;\n        transform: translateY(10px) scale(0.96);\n        transform-box: fill-box;\n        transform-origin: center;\n        transition: opacity 0.45s ease, transform 0.5s cubic-bezier(0.2, 0.75, 0.25, 1);\n    }\n    .reveal.show { opacity: 1; transform: translateY(0) scale(1); }\n\n    /* ── ARROW SHAFT (self-drawing) ── */\n    .arrow-shaft {\n        fill: none;\n        stroke: var(--arrow);\n        stroke-width: 2.5;\n        stroke-linecap: round;\n        stroke-linejoin: round;\n        stroke-dasharray: 1;\n        stroke-dashoffset: 1;\n        transition: stroke-dashoffset 0.5s ease;\n    }\n    .arrow-shaft.show { stroke-dashoffset: 0; }\n\n    /* ── ARROW HEAD (pops in as the shaft finishes drawing) ── */\n    .arrow-head {\n        fill: var(--arrow);\n        opacity: 0;\n        transform: scale(0.3);\n        transform-box: fill-box;\n        transform-origin: center;\n        transition: opacity 0.25s ease 0.32s, transform 0.25s ease 0.32s;\n    }\n    .arrow-head.show { opacity: 1; transform: scale(1); }\n\n    @media (prefers-reduced-motion: reduce) {\n        .reveal, .arrow-shaft, .arrow-head { transition: none; }\n    }\n</style>\n</head>\n<body>\n\n    <div class=\"stage-heading\">\n        <h1>Waterfall Model</h1>\n        <p>Each phase is completed fully before the next begins</p>\n    </div>\n\n    <div class=\"stage\">\n        <svg viewBox=\"0 0 890 460\" role=\"img\" aria-label=\"Animated Waterfall Model diagram\">\n\n            <!-- ═══ CONNECTOR ARROWS (drawn beneath the blocks) ═══ -->\n\n            <!-- Requirement Analysis → label -->\n            <path class=\"arrow-shaft\" id=\"a-req-l1\" pathLength=\"1\" d=\"M170,59 L206,59\"/>\n            <polygon class=\"arrow-head\" id=\"h-req-l1\" points=\"210,59 201,54 201,64\"/>\n\n            <!-- Requirement Analysis → Design -->\n            <path class=\"arrow-shaft\" id=\"a-req-des\" pathLength=\"1\" d=\"M64,88 L64,123 L151,123\"/>\n            <polygon class=\"arrow-head\" id=\"h-req-des\" points=\"155,123 146,118 146,128\"/>\n\n            <!-- Design → Development -->\n            <path class=\"arrow-shaft\" id=\"a-des-dev\" pathLength=\"1\" d=\"M179,146 L179,193 L266,193\"/>\n            <polygon class=\"arrow-head\" id=\"h-des-dev\" points=\"270,193 261,188 261,198\"/>\n\n            <!-- Development → label -->\n            <path class=\"arrow-shaft\" id=\"a-dev-l2\" pathLength=\"1\" d=\"M420,193 L466,193\"/>\n            <polygon class=\"arrow-head\" id=\"h-dev-l2\" points=\"470,193 461,188 461,198\"/>\n\n            <!-- Development → Testing -->\n            <path class=\"arrow-shaft\" id=\"a-dev-test\" pathLength=\"1\" d=\"M294,216 L294,263 L381,263\"/>\n            <polygon class=\"arrow-head\" id=\"h-dev-test\" points=\"385,263 376,258 376,268\"/>\n\n            <!-- Testing → label -->\n            <path class=\"arrow-shaft\" id=\"a-test-l3\" pathLength=\"1\" d=\"M489,263 L541,263\"/>\n            <polygon class=\"arrow-head\" id=\"h-test-l3\" points=\"545,263 536,258 536,268\"/>\n\n            <!-- Testing → Deployment -->\n            <path class=\"arrow-shaft\" id=\"a-test-dep\" pathLength=\"1\" d=\"M409,286 L409,333 L496,333\"/>\n            <polygon class=\"arrow-head\" id=\"h-test-dep\" points=\"500,333 491,328 491,338\"/>\n\n            <!-- Deployment → Maintenance -->\n            <path class=\"arrow-shaft\" id=\"a-dep-mnt\" pathLength=\"1\" d=\"M524,356 L524,403 L611,403\"/>\n            <polygon class=\"arrow-head\" id=\"h-dep-mnt\" points=\"615,403 606,398 606,408\"/>\n\n            <!-- Maintenance → label (points left) -->\n            <path class=\"arrow-shaft\" id=\"a-mnt-l4\" pathLength=\"1\" d=\"M615,403 L589,403\"/>\n            <polygon class=\"arrow-head\" id=\"h-mnt-l4\" points=\"585,403 594,398 594,408\"/>\n\n\n            <!-- ═══ PHASE BLOCKS ═══ -->\n\n            <g class=\"reveal blk\" id=\"b-req\">\n                <rect x=\"40\" y=\"30\" width=\"130\" height=\"58\" rx=\"8\" fill=\"var(--req)\"/>\n                <text x=\"105\" y=\"53\" text-anchor=\"middle\" class=\"blk-t\">Requirement</text>\n                <text x=\"105\" y=\"73\" text-anchor=\"middle\" class=\"blk-t\">Analysis</text>\n            </g>\n\n            <g class=\"reveal blk\" id=\"b-des\">\n                <rect x=\"155\" y=\"100\" width=\"104\" height=\"46\" rx=\"8\" fill=\"var(--des)\"/>\n                <text x=\"207\" y=\"128\" text-anchor=\"middle\" class=\"blk-t\">Design</text>\n            </g>\n\n            <g class=\"reveal blk\" id=\"b-dev\">\n                <rect x=\"270\" y=\"170\" width=\"150\" height=\"46\" rx=\"8\" fill=\"var(--dev)\"/>\n                <text x=\"345\" y=\"198\" text-anchor=\"middle\" class=\"blk-t\">Development</text>\n            </g>\n\n            <g class=\"reveal blk\" id=\"b-test\">\n                <rect x=\"385\" y=\"240\" width=\"104\" height=\"46\" rx=\"8\" fill=\"var(--test)\"/>\n                <text x=\"437\" y=\"268\" text-anchor=\"middle\" class=\"blk-t\">Testing</text>\n            </g>\n\n            <g class=\"reveal blk\" id=\"b-dep\">\n                <rect x=\"500\" y=\"310\" width=\"150\" height=\"46\" rx=\"8\" fill=\"var(--dep)\"/>\n                <text x=\"575\" y=\"338\" text-anchor=\"middle\" class=\"blk-t\">Deployment</text>\n            </g>\n\n            <g class=\"reveal blk\" id=\"b-mnt\">\n                <rect x=\"615\" y=\"380\" width=\"150\" height=\"46\" rx=\"8\" fill=\"var(--mnt)\"/>\n                <text x=\"690\" y=\"408\" text-anchor=\"middle\" class=\"blk-t\">Maintenance</text>\n            </g>\n\n\n            <!-- ═══ EXPLANATION LABELS ═══ -->\n\n            <g class=\"reveal lbl\" id=\"l1\">\n                <rect class=\"lbl-box\" x=\"210\" y=\"39\" width=\"235\" height=\"40\" rx=\"8\"/>\n                <text x=\"224\" y=\"64\" class=\"lbl-t\">Plan everything <tspan class=\"em\">beforehand</tspan></text>\n            </g>\n\n            <g class=\"reveal lbl\" id=\"l2\">\n                <rect class=\"lbl-box\" x=\"470\" y=\"173\" width=\"250\" height=\"40\" rx=\"8\"/>\n                <text x=\"484\" y=\"198\" class=\"lbl-t\">Developers <tspan class=\"em\">code complete app</tspan></text>\n            </g>\n\n            <g class=\"reveal lbl\" id=\"l3\">\n                <rect class=\"lbl-box\" x=\"545\" y=\"243\" width=\"320\" height=\"40\" rx=\"8\"/>\n                <text x=\"559\" y=\"268\" class=\"lbl-t\">Testing after <tspan class=\"em\">everything has developed</tspan></text>\n            </g>\n\n            <g class=\"reveal lbl\" id=\"l4\">\n                <rect class=\"lbl-box\" x=\"335\" y=\"383\" width=\"250\" height=\"40\" rx=\"8\"/>\n                <text x=\"349\" y=\"408\" class=\"lbl-t\">Maintenance <tspan class=\"em\">after deployment</tspan></text>\n            </g>\n\n        </svg>\n    </div>\n\n<script>\n    // Interleaved reveal order: each phase block, then its label, then the\n    // connector arrow leading down to the next phase.\n    const steps = [\n        ['#b-req'],\n        ['#a-req-l1', '#h-req-l1', '#l1'],\n        ['#a-req-des', '#h-req-des'],\n        ['#b-des'],\n        ['#a-des-dev', '#h-des-dev'],\n        ['#b-dev'],\n        ['#a-dev-l2', '#h-dev-l2', '#l2'],\n        ['#a-dev-test', '#h-dev-test'],\n        ['#b-test'],\n        ['#a-test-l3', '#h-test-l3', '#l3'],\n        ['#a-test-dep', '#h-test-dep'],\n        ['#b-dep'],\n        ['#a-dep-mnt', '#h-dep-mnt'],\n        ['#b-mnt'],\n        ['#a-mnt-l4', '#h-mnt-l4', '#l4'],\n    ];\n\n    const STEP = 620;   // ms between reveals\n    const HOLD = 2600;  // ms to hold the finished diagram\n    const GAP  = 700;   // ms blank before replaying\n\n    const allEls = () => document.querySelectorAll('.reveal, .arrow-shaft, .arrow-head');\n\n    function revealAll() {\n        allEls().forEach(el => el.classList.add('show'));\n    }\n    function clearAll() {\n        allEls().forEach(el => el.classList.remove('show'));\n    }\n\n    // Respect reduced-motion: show the full diagram, no looping.\n    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {\n        revealAll();\n    } else {\n        const playOnce = () => {\n            steps.forEach((group, i) => {\n                setTimeout(() => {\n                    group.forEach(sel => document.querySelector(sel)?.classList.add('show'));\n                }, i * STEP);\n            });\n        };\n\n        const loop = () => {\n            playOnce();\n            const total = steps.length * STEP + HOLD;\n            setTimeout(() => {\n                clearAll();\n                setTimeout(loop, GAP);\n            }, total);\n        };\n\n        loop();\n    }\n</script>\n\n</body>\n</html>\n"
      },
