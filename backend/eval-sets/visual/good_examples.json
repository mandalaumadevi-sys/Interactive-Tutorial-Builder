      "context": {
        "session_name": "Agile Model and Frameworks",
        "image_id": "img_ag_01",
        "concept": "Agile Model",
        "visual_type": "lifecycle",
        "source_image": {
          "alt": "Agile iterative sprint cycle",
          "caption": "Plan → build → review → repeat"
        },
        "relevant_paragraph": "Agile develops software in small repeated cycles called iterations, getting feedback early and often."
      },
      "output": {
        "image_id": "img_ag_01",
        "visual_type": "lifecycle",
        "reference_file": "agile-model-animation.html",
        "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Agile Model — Animated</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap\" rel=\"stylesheet\">\n<style>\n    :root {\n        --hubText: #6b7280;   /* SPRINT n labels */\n        --hubBorder: #e3e7ec;\n        --lblText: #ffffff;   /* phase names on arrows */\n    }\n\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n\n    body {\n        font-family: 'Inter', sans-serif;\n        background: #f8fafc;\n        min-height: 100vh;\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        justify-content: center;\n        padding: 40px 20px;\n        color: #1f2937;\n    }\n\n    .stage-heading { text-align: center; margin-bottom: 6px; }\n    .stage-heading h1 { font-size: 1.6rem; font-weight: 700; color: #1f2937; }\n    .stage-heading p  { font-size: 0.95rem; color: #6b7280; font-style: italic; margin-top: 4px; }\n\n    .stage {\n        width: 100%;\n        max-width: 940px;\n        background: #ffffff;\n        border: 1px solid #eef2f7;\n        border-radius: 16px;\n        box-shadow: 0 8px 30px rgba(15, 23, 42, 0.06);\n        padding: 28px 24px 32px;\n        margin-top: 22px;\n    }\n\n    svg { width: 100%; height: auto; display: block; }\n\n    /* ── TEXT ── */\n    .hub-name  { fill: var(--hubText); font-family: 'Inter', sans-serif; font-weight: 800; font-size: 17px; letter-spacing: 0.5px; }\n    .hub-num   { fill: var(--hubText); font-family: 'Inter', sans-serif; font-weight: 800; font-size: 22px; }\n    .phase-t   { fill: var(--lblText); font-family: 'Inter', sans-serif; font-weight: 700; font-size: 11px; letter-spacing: 0.6px; }\n    .launch-t  { fill: var(--lblText); font-family: 'Inter', sans-serif; font-weight: 700; font-size: 11px; letter-spacing: 0.6px; }\n\n    .seg path, .launch path { filter: drop-shadow(0 2px 3px rgba(0,0,0,0.16)); }\n    .hub circle { filter: drop-shadow(0 2px 4px rgba(0,0,0,0.06)); }\n\n    /* ── REVEAL ANIMATION ── */\n    .reveal {\n        opacity: 0;\n        transform: scale(0.82);\n        transform-box: fill-box;\n        transform-origin: center;\n        transition: opacity 0.4s ease, transform 0.45s cubic-bezier(0.2, 0.75, 0.25, 1);\n    }\n    .reveal.show { opacity: 1; transform: scale(1); }\n\n    .launch.reveal { transform: translateX(-14px); }\n    .launch.reveal.show { transform: translateX(0); }\n\n    @media (prefers-reduced-motion: reduce) {\n        .reveal { transition: none; }\n    }\n</style>\n</head>\n<body>\n\n    <div class=\"stage-heading\">\n        <h1>Agile Model</h1>\n        <p>Work ships in short, repeating sprints — each cycle plans, builds, tests &amp; reviews</p>\n    </div>\n\n    <div class=\"stage\">\n        <svg id=\"agile\" viewBox=\"0 0 900 360\" role=\"img\" aria-label=\"Animated Agile Model diagram with three sprint cycles\"></svg>\n    </div>\n\n<script>\n    // ─────────────────────────────────────────────────────────────\n    // Agile diagram, generated as inline SVG then revealed step-by-step.\n    // Mirrors the waterfall reference: a .reveal/.show CSS technique driven\n    // by a JS step sequence that plays once, holds, clears, and replays.\n    // ─────────────────────────────────────────────────────────────\n\n    const SVGNS = \"http://www.w3.org/2000/svg\";\n    const svg = document.getElementById(\"agile\");\n\n    // Phase order around the ring, counter-clockwise as in the source image.\n    // Angle convention: 0°=right (3 o'clock), 90°=bottom, 180°=left, 270°=top\n    // (y-down screen ⇒ increasing angle is clockwise). Forward = decreasing angle.\n    const PHASES = [\n        { key: \"plan\",    label: \"PLAN\",    angle: 120 },\n        { key: \"design\",  label: \"DESIGN\",  angle: 60  },\n        { key: \"develop\", label: \"DEVELOP\", angle: 0   },\n        { key: \"test\",    label: \"TEST\",    angle: 300 },\n        { key: \"deploy\",  label: \"DEPLOY\",  angle: 240 },\n        { key: \"review\",  label: \"REVIEW\",  angle: 180 },\n    ];\n\n    // Per-sprint colour ramp (light → dark), matching the image's palette.\n    const SPRINTS = [\n        { num: \"1\", cx: 175, c0: \"#e74c3c\", c1: \"#7d1620\", launch: \"#a52a22\" },  // reds\n        { num: \"2\", cx: 450, c0: \"#f6cf3f\", c1: \"#e2761a\", launch: \"#ef9b18\" },  // yellow → orange\n        { num: \"3\", cx: 725, c0: \"#b6cc3b\", c1: \"#1e7a3a\", launch: \"#5aa02f\" },  // lime → green\n    ];\n\n    const CY = 168, RO = 88, RI = 54, RMID = (RO + RI) / 2;\n\n    const rad = d => d * Math.PI / 180;\n    const P = (cx, cy, r, deg) => ({ x: cx + r * Math.cos(rad(deg)), y: cy + r * Math.sin(rad(deg)) });\n\n    function lerpColor(a, b, t) {\n        const pa = [parseInt(a.slice(1, 3), 16), parseInt(a.slice(3, 5), 16), parseInt(a.slice(5, 7), 16)];\n        const pb = [parseInt(b.slice(1, 3), 16), parseInt(b.slice(3, 5), 16), parseInt(b.slice(5, 7), 16)];\n        const mix = pa.map((v, i) => Math.round(v + (pb[i] - v) * t));\n        return \"#\" + mix.map(v => v.toString(16).padStart(2, \"0\")).join(\"\");\n    }\n\n    // A curved arrow (annular sector with an arrowhead at the leading end).\n    function segPath(cx, cy, c) {\n        const aT = c + 25, aB = c - 11, aTip = c - 25, barb = 7;\n        const oT = P(cx, cy, RO, aT), oB = P(cx, cy, RO, aB);\n        const iT = P(cx, cy, RI, aT), iB = P(cx, cy, RI, aB);\n        const bo = P(cx, cy, RO + barb, aB), bi = P(cx, cy, RI - barb, aB);\n        const tip = P(cx, cy, RMID, aTip);\n        return `M${oT.x},${oT.y} A${RO},${RO} 0 0 0 ${oB.x},${oB.y}`\n             + ` L${bo.x},${bo.y} L${tip.x},${tip.y} L${bi.x},${bi.y} L${iB.x},${iB.y}`\n             + ` A${RI},${RI} 0 0 1 ${iT.x},${iT.y} Z`;\n    }\n\n    // Horizontal PLAN ▸ LAUNCH arrow that chains one sprint into the next.\n    function launchPath(cx) {\n        const x0 = cx - 96, x1 = cx + 96, yb = CY + RO + 28, h = 14, head = 16;\n        return `M${x0},${yb - h} L${x1 - head},${yb - h} L${x1 - head},${yb - h - 7}`\n             + ` L${x1},${yb} L${x1 - head},${yb + h + 7} L${x1 - head},${yb + h} L${x0},${yb + h} Z`;\n    }\n\n    function el(tag, attrs, parent) {\n        const n = document.createElementNS(SVGNS, tag);\n        for (const k in attrs) n.setAttribute(k, attrs[k]);\n        if (parent) parent.appendChild(n);\n        return n;\n    }\n\n    const steps = [];   // reveal order: array of selector-arrays\n\n    SPRINTS.forEach(sp => {\n        const sid = `s${sp.num}`;\n\n        // ── hub (centre circle + SPRINT label) ──\n        const hub = el(\"g\", { id: `${sid}-hub`, class: \"reveal hub\" }, svg);\n        el(\"circle\", { cx: sp.cx, cy: CY, r: RI - 4, fill: \"#ffffff\", stroke: \"var(--hubBorder)\", \"stroke-width\": 1.5 }, hub);\n        const tName = el(\"text\", { x: sp.cx, y: CY - 4, \"text-anchor\": \"middle\", class: \"hub-name\" }, hub);\n        tName.textContent = \"SPRINT\";\n        const tNum = el(\"text\", { x: sp.cx, y: CY + 20, \"text-anchor\": \"middle\", class: \"hub-num\" }, hub);\n        tNum.textContent = sp.num;\n        steps.push([`#${sid}-hub`]);\n\n        // ── six phase arrows ──\n        PHASES.forEach((ph, i) => {\n            const fill = lerpColor(sp.c0, sp.c1, i / (PHASES.length - 1));\n            const g = el(\"g\", { id: `${sid}-${ph.key}`, class: \"reveal seg\" }, svg);\n            el(\"path\", { d: segPath(sp.cx, CY, ph.angle), fill }, g);\n\n            // phase label, rotated to follow the ring (kept upright)\n            const pos = P(sp.cx, CY, RMID, ph.angle);\n            let rot = ph.angle + 90;\n            if (rot >= 90 && rot <= 270) rot -= 180;\n            const t = el(\"text\", {\n                x: pos.x, y: pos.y, \"text-anchor\": \"middle\", \"dominant-baseline\": \"central\",\n                class: \"phase-t\", transform: `rotate(${rot} ${pos.x} ${pos.y})`,\n            }, g);\n            t.textContent = ph.label;\n\n            steps.push([`#${sid}-${ph.key}`]);\n        });\n\n        // ── bottom launch arrow ──\n        const lg = el(\"g\", { id: `${sid}-launch`, class: \"reveal launch\" }, svg);\n        el(\"path\", { d: launchPath(sp.cx), fill: sp.launch }, lg);\n        const yb = CY + RO + 28;\n        el(\"line\", { x1: sp.cx - 8, y1: yb - 12, x2: sp.cx - 8, y2: yb + 12, stroke: \"rgba(255,255,255,0.5)\", \"stroke-width\": 1.5 }, lg);\n        const lPlan = el(\"text\", { x: sp.cx - 52, y: yb + 1, \"text-anchor\": \"middle\", \"dominant-baseline\": \"central\", class: \"launch-t\" }, lg);\n        lPlan.textContent = \"PLAN\";\n        const lLaunch = el(\"text\", { x: sp.cx + 38, y: yb + 1, \"text-anchor\": \"middle\", \"dominant-baseline\": \"central\", class: \"launch-t\" }, lg);\n        lLaunch.textContent = \"LAUNCH\";\n        steps.push([`#${sid}-launch`]);\n    });\n\n    // ───────────────────────── playback ─────────────────────────\n    const STEP = 420;   // ms between reveals\n    const HOLD = 2800;  // ms to hold the finished diagram\n    const GAP  = 700;   // ms blank before replaying\n\n    const allEls = () => document.querySelectorAll(\".reveal\");\n    const revealAll = () => allEls().forEach(e => e.classList.add(\"show\"));\n    const clearAll  = () => allEls().forEach(e => e.classList.remove(\"show\"));\n\n    if (window.matchMedia(\"(prefers-reduced-motion: reduce)\").matches) {\n        revealAll();\n    } else {\n        const playOnce = () => steps.forEach((group, i) => setTimeout(() => {\n            group.forEach(sel => svg.querySelector(sel)?.classList.add(\"show\"));\n        }, i * STEP));\n\n        const loop = () => {\n            playOnce();\n            const total = steps.length * STEP + HOLD;\n            setTimeout(() => { clearAll(); setTimeout(loop, GAP); }, total);\n        };\n        loop();\n    }\n</script>\n\n</body>\n</html>\n"
      },
