        "reference_file": "v-model-animation.html",
        "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>V-Model — Animated</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap\" rel=\"stylesheet\">\n<style>\n    :root {\n        --boxText: #ffffff;\n        --armText: #ffffff;\n        --link: #8a8f98;\n    }\n\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n\n    body {\n        font-family: 'Inter', sans-serif;\n        background: #f8fafc;\n        min-height: 100vh;\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        justify-content: center;\n        padding: 40px 20px;\n        color: #1f2937;\n    }\n\n    .stage-heading { text-align: center; margin-bottom: 6px; }\n    .stage-heading h1 { font-size: 1.6rem; font-weight: 700; color: #1f2937; }\n    .stage-heading p  { font-size: 0.95rem; color: #6b7280; font-style: italic; margin-top: 4px; }\n\n    .stage {\n        width: 100%;\n        max-width: 940px;\n        background: #ffffff;\n        border: 1px solid #eef2f7;\n        border-radius: 16px;\n        box-shadow: 0 8px 30px rgba(15, 23, 42, 0.06);\n        padding: 28px 24px 32px;\n        margin-top: 22px;\n    }\n\n    svg { width: 100%; height: auto; display: block; }\n\n    /* ── TEXT ── */\n    .box-t  { fill: var(--boxText); font-family: 'Inter', sans-serif; font-weight: 700; font-size: 13px; }\n    .arm-t  { fill: var(--armText); font-family: 'Inter', sans-serif; font-weight: 800; font-size: 17px; letter-spacing: 0.5px; }\n\n    .box polygon, .coding polygon { filter: drop-shadow(0 2px 4px rgba(0,0,0,0.20)); }\n    .arm polygon  { filter: drop-shadow(0 2px 4px rgba(0,0,0,0.10)); }\n\n    /* ── REVEAL ANIMATION ── */\n    .reveal {\n        opacity: 0;\n        transform: scale(0.84);\n        transform-box: fill-box;\n        transform-origin: center;\n        transition: opacity 0.4s ease, transform 0.45s cubic-bezier(0.2, 0.75, 0.25, 1);\n    }\n    .reveal.show { opacity: 1; transform: scale(1); }\n\n    .link.reveal { transform: scaleX(0.4); }\n    .link.reveal.show { transform: scaleX(1); }\n\n    @media (prefers-reduced-motion: reduce) {\n        .reveal { transition: none; }\n    }\n</style>\n</head>\n<body>\n\n    <div class=\"stage-heading\">\n        <h1>V-Model</h1>\n        <p>Every build phase on the left is verified by a matching test phase on the right</p>\n    </div>\n\n    <div class=\"stage\">\n        <svg id=\"vmodel\" viewBox=\"0 0 900 540\" role=\"img\" aria-label=\"Animated V-Model diagram: verification phase, validation phase, and Coding at the vertex\"></svg>\n    </div>\n\n<script>\n    // ─────────────────────────────────────────────────────────────\n    // V-Model, generated as inline SVG then revealed level-by-level in\n    // verification↔validation pairs (left build phase → matching right test\n    // phase → the link between them), with Coding revealed last at the vertex.\n    // Same .reveal/.show + replay-loop technique as the waterfall/agile files.\n    // ─────────────────────────────────────────────────────────────\n\n    const SVGNS = \"http://www.w3.org/2000/svg\";\n    const svg = document.getElementById(\"vmodel\");\n\n    // Corresponding build (left) / test (right) phases, top → bottom.\n    const LEVELS = [\n        { y: 90,\n          left:  { key: \"req\",  lines: [\"Requirement\", \"Gathering\"], cx: 210, color: \"#c1673c\" },\n          right: { key: \"acc\",  lines: [\"Acceptance\", \"Testing\"],    cx: 690, color: \"#5f8c92\" } },\n        { y: 168,\n          left:  { key: \"sysa\", lines: [\"System\", \"Analysis\"],       cx: 255, color: \"#d6a04e\" },\n          right: { key: \"syst\", lines: [\"System\", \"Testing\"],        cx: 645, color: \"#6f9aa0\" } },\n        { y: 246,\n          left:  { key: \"swd\",  lines: [\"Software\", \"Design\"],        cx: 300, color: \"#cf9a63\" },\n          right: { key: \"intt\", lines: [\"Integration\", \"Testing\"],   cx: 600, color: \"#7ba6a6\" } },\n        { y: 324,\n          left:  { key: \"mod\",  lines: [\"Module\", \"Design\"],          cx: 345, color: \"#b27d4a\" },\n          right: { key: \"unit\", lines: [\"Unit\", \"Testing\"],          cx: 555, color: \"#87b0ad\" } },\n    ];\n    const CODING = { cx: 450, cy: 438, color: \"#8a5a3c\" };\n\n    const BW = 120, BH = 48, SHEAR = 10;   // box width, height, parallelogram shear\n\n    function el(tag, attrs, parent) {\n        const n = document.createElementNS(SVGNS, tag);\n        for (const k in attrs) n.setAttribute(k, attrs[k]);\n        if (parent) parent.appendChild(n);\n        return n;\n    }\n\n    // Parallelogram corners (s = horizontal shear; left arm leans one way, right the other).\n    function boxPts(cx, cy, w, h, s) {\n        const hw = w / 2, hh = h / 2;\n        return [[cx - hw + s, cy - hh], [cx + hw + s, cy - hh],\n                [cx + hw - s, cy + hh], [cx - hw - s, cy + hh]]\n            .map(p => p.map(v => v.toFixed(1)).join(\",\")).join(\" \");\n    }\n\n    function addBox(id, cls, cx, cy, color, lines, shear) {\n        const g = el(\"g\", { id, class: `reveal box ${cls}` }, svg);\n        el(\"polygon\", { points: boxPts(cx, cy, BW, BH, shear), fill: color }, g);\n        const oy = lines.length > 1 ? -5 : 5;\n        lines.forEach((ln, i) => {\n            const t = el(\"text\", { x: cx, y: cy + oy + i * 17 + 5, \"text-anchor\": \"middle\", class: \"box-t\" }, g);\n            t.textContent = ln;\n        });\n        return g;\n    }\n\n    // Tapered arrow band (shaft + arrowhead) from (sx,sy) to (ex,ey), tip at the end.\n    function armBand(sx, sy, ex, ey, halfW, headLen, headW) {\n        const dx = ex - sx, dy = ey - sy, len = Math.hypot(dx, dy);\n        const ux = dx / len, uy = dy / len, px = -uy, py = ux;\n        const bx = ex - ux * headLen, by = ey - uy * headLen;\n        const pts = [\n            [sx + px * halfW, sy + py * halfW],\n            [bx + px * halfW, by + py * halfW],\n            [bx + px * headW, by + py * headW],\n            [ex, ey],\n            [bx - px * headW, by - py * headW],\n            [bx - px * halfW, by - py * halfW],\n            [sx - px * halfW, sy - py * halfW],\n        ];\n        return pts.map(p => p.map(v => v.toFixed(1)).join(\",\")).join(\" \");\n    }\n\n    function addArm(id, sx, sy, ex, ey, color, label) {\n        const g = el(\"g\", { id, class: \"reveal arm\" }, svg);\n        el(\"polygon\", { points: armBand(sx, sy, ex, ey, 22, 34, 33), fill: color }, g);\n        const mx = sx + (ex - sx) * 0.46, my = sy + (ey - sy) * 0.46;\n        let ang = Math.atan2(ey - sy, ex - sx) * 180 / Math.PI;\n        const t = el(\"text\", { x: mx, y: my, \"text-anchor\": \"middle\", \"dominant-baseline\": \"central\",\n                               class: \"arm-t\", transform: `rotate(${ang.toFixed(1)} ${mx} ${my})` }, g);\n        t.textContent = label;\n        return g;\n    }\n\n    // Horizontal double-headed link between a left box and its right counterpart.\n    function addLink(id, x1, x2, y) {\n        const g = el(\"g\", { id, class: \"reveal link\" }, svg);\n        el(\"line\", { x1: x1 + 9, y1: y, x2: x2 - 9, y2: y, stroke: \"var(--link)\",\n                     \"stroke-width\": 2.5, \"stroke-dasharray\": \"6 5\", \"stroke-linecap\": \"round\" }, g);\n        el(\"polygon\", { points: `${x1},${y} ${x1 + 11},${y - 6} ${x1 + 11},${y + 6}`, fill: \"var(--link)\" }, g);   // ◄ left\n        el(\"polygon\", { points: `${x2},${y} ${x2 - 11},${y - 6} ${x2 - 11},${y + 6}`, fill: \"var(--link)\" }, g);   // ► right\n        return g;\n    }\n\n    const steps = [];\n\n    // ── V skeleton: the two big arms + their phase labels (revealed first) ──\n    addArm(\"arm-left\",  95, 66, 372, 500, \"#b9824f\", \"Verification Phase\");   // points down to vertex\n    addArm(\"arm-right\", 528, 500, 805, 66, \"#7c9ea0\", \"Validation Phase\");    // points up to the top\n    steps.push([\"#arm-left\", \"#arm-right\"]);\n\n    // ── verification ↔ validation pairs, level by level ──\n    LEVELS.forEach((lv, i) => {\n        addBox(`L${i}-left`,  \"left\",  lv.left.cx,  lv.y, lv.left.color,  lv.left.lines,  -SHEAR);\n        addBox(`L${i}-right`, \"right\", lv.right.cx, lv.y, lv.right.color, lv.right.lines,  SHEAR);\n        addLink(`link${i}`, lv.left.cx + BW / 2 - SHEAR + 4, lv.right.cx - BW / 2 + SHEAR - 4, lv.y);\n        steps.push([`#L${i}-left`]);\n        steps.push([`#L${i}-right`]);\n        steps.push([`#link${i}`]);\n    });\n\n    // ── Coding at the vertex (last) ──\n    const cg = el(\"g\", { id: \"coding\", class: \"reveal coding\" }, svg);\n    el(\"polygon\", { points: boxPts(CODING.cx, CODING.cy, 150, 50, 0), fill: CODING.color }, cg);\n    const ct = el(\"text\", { x: CODING.cx, y: CODING.cy + 5, \"text-anchor\": \"middle\", class: \"box-t\" }, cg);\n    ct.textContent = \"Coding\";\n    steps.push([\"#coding\"]);\n\n    // ───────────────────────── playback ─────────────────────────\n    const STEP = 430;   // ms between reveals\n    const HOLD = 2800;  // ms to hold the finished diagram\n    const GAP  = 700;   // ms blank before replaying\n\n    const allEls = () => document.querySelectorAll(\".reveal\");\n    const revealAll = () => allEls().forEach(e => e.classList.add(\"show\"));\n    const clearAll  = () => allEls().forEach(e => e.classList.remove(\"show\"));\n\n    if (window.matchMedia(\"(prefers-reduced-motion: reduce)\").matches) {\n        revealAll();\n    } else {\n        const playOnce = () => steps.forEach((group, i) => setTimeout(() => {\n            group.forEach(sel => svg.querySelector(sel)?.classList.add(\"show\"));\n        }, i * STEP));\n\n        const loop = () => {\n            playOnce();\n            const total = steps.length * STEP + HOLD;\n            setTimeout(() => { clearAll(); setTimeout(loop, GAP); }, total);\n        };\n        loop();\n    }\n</script>\n\n</body>\n</html>\n"
