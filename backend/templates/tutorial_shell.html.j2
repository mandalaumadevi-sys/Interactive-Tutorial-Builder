<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }}</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Inter', sans-serif; background:#f8fafc; min-height:100vh; color:#374151; padding-bottom:110px; scroll-behavior:smooth; }

/* scrolling feed: revealed steps stay visible */
.step { display:none; }
.step.active { display:block; animation:fadeIn .4s ease; scroll-margin-top:16px; }
.step.active + .step.active { border-top:1px solid #e5e7eb; }
@keyframes fadeIn { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }

/* continue bar */
.continue-bar { position:fixed; bottom:0; left:0; right:0; background:#fff; border-top:1px solid #e5e7eb; padding:14px 40px; display:flex; align-items:center; justify-content:space-between; z-index:100; box-shadow:0 -4px 12px rgba(0,0,0,.06); }
.progress-info { display:flex; flex-direction:column; gap:6px; min-width:180px; }
.progress-bar-wrap { width:180px; height:4px; background:#e5e7eb; border-radius:99px; overflow:hidden; }
.progress-bar-fill { height:100%; background:#3b82f6; border-radius:99px; transition:width .4s ease; }
.step-label { font-size:.78rem; color:#9ca3af; }
.step-label span { color:#3b82f6; font-weight:600; }
#continue-btn { background:#3b82f6; color:#fff; border:none; border-radius:8px; padding:10px 24px; font:600 .9rem 'Inter',sans-serif; cursor:pointer; display:flex; align-items:center; gap:8px; transition:background .2s,transform .1s; }
#continue-btn:hover:not(:disabled){ background:#2563eb; } #continue-btn:active:not(:disabled){ transform:scale(.97); }
#continue-btn:disabled { opacity:.38; cursor:default; pointer-events:none; }
#continue-btn.finish { background:#22c55e; } #continue-btn.finish:hover:not(:disabled){ background:#16a34a; }

/* header */
.header { display:flex; }
.header-accent { width:8px; background:#3b82f6; min-height:120px; flex-shrink:0; }
.header-accent.quiz { background:#6366f1; } .header-accent.assess { background:#0ea5e9; }
.header-content { padding:36px 0 36px 16px; }
.header h1 { font-size:2.1rem; font-weight:700; color:#1f2937; margin-bottom:6px; }
.header p { font-size:1.15rem; color:#6b7280; font-style:italic; }
.badge { display:inline-block; background:#ede9fe; color:#4f46e5; font:700 .72rem 'Inter'; text-transform:uppercase; letter-spacing:.07em; padding:4px 10px; border-radius:20px; border:1px solid #c4b5fd; margin-bottom:6px; }

.main-content { padding:24px 40px; }
.divider { border:none; border-top:1px solid #e5e7eb; margin:28px 40px; }
.section-label h2 { font-size:1.3rem; font-weight:700; color:#1f2937; margin-bottom:4px; }
.section-label p { font-size:.9rem; color:#6b7280; font-style:italic; }

/* content components (agents are instructed to use these classes) */
.info-grid { display:grid; grid-template-columns:1fr 1fr; gap:24px; margin-bottom:24px; }
.card { border:1px solid #e5e7eb; border-radius:8px; padding:20px; background:#fff; box-shadow:0 1px 3px rgba(0,0,0,.1); }
.card-header { display:flex; align-items:center; margin-bottom:12px; }
.card-title { font-weight:700; color:#1f2937; font-size:.95rem; }
.bullet-list { list-style:none; display:flex; flex-direction:column; gap:8px; }
.bullet-item { display:flex; align-items:flex-start; line-height:1.5; }
.bullet-dot { width:6px; height:6px; border-radius:50%; background:#3b82f6; margin-top:8px; margin-right:8px; flex-shrink:0; }
.bullet-dot.green{ background:#22c55e; } .bullet-dot.red{ background:#ef4444; }
.bullet-text { color:#6b7280; font-size:.9rem; }
.callout { background:#eff6ff; border-left:4px solid #3b82f6; border-radius:0 8px 8px 0; padding:16px 20px; margin:20px 0; color:#374151; font-size:.9rem; line-height:1.7; }
.callout strong { color:#1d4ed8; }
.table-wrap { overflow-x:auto; margin:16px 0; }
table { width:100%; border-collapse:collapse; font-size:.9rem; }
thead tr { background:#f9fafb; } thead th { text-align:left; padding:10px 16px; color:#374151; font-weight:600; border-bottom:2px solid #e5e7eb; }
tbody tr { border-bottom:1px solid #e5e7eb; } tbody td { padding:10px 16px; color:#6b7280; vertical-align:top; } tbody td:first-child { color:#1f2937; font-weight:500; }
.img-box { border:1px solid #e5e7eb; border-radius:8px; padding:16px; background:#f9fafb; margin:16px 0; text-align:center; }
.img-box img { max-width:100%; border-radius:6px; }
.img-caption { font-size:.8rem; color:#9ca3af; margin-top:8px; font-style:italic; }
.pros-cons-row { display:grid; grid-template-columns:1fr 1fr; gap:24px; margin:16px 0; }
.pros-card { border:1px solid #bbf7d0; border-top:3px solid #22c55e; border-radius:8px; padding:16px 20px; background:#f0fdf4; }
.cons-card { border:1px solid #fecaca; border-top:3px solid #ef4444; border-radius:8px; padding:16px 20px; background:#fff5f5; }
.pros-card h4 { color:#15803d; } .cons-card h4 { color:#b91c1c; }
.pros-card h4,.cons-card h4 { font-weight:700; margin-bottom:12px; font-size:.85rem; text-transform:uppercase; letter-spacing:.05em; }
.when-card { background:#f0f9ff; border:1px solid #bae6fd; border-radius:8px; padding:16px 20px; margin:16px 0; }
.when-card h4 { font-weight:600; color:#0369a1; margin-bottom:10px; font-size:.9rem; }
.tags-row { display:flex; flex-wrap:wrap; gap:10px; margin:14px 0; }
.tag { border:1px solid #e5e7eb; border-radius:8px; padding:6px 14px; background:#f9fafb; color:#374151; font-size:.875rem; font-weight:500; }
.vv-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin:16px 0; }
.vv-card { border:1px solid #e5e7eb; border-radius:8px; padding:16px 20px; background:#fff; box-shadow:0 1px 3px rgba(0,0,0,.07); }
.vv-label { display:inline-block; background:#eff6ff; color:#2563eb; font:700 .75rem 'Inter'; text-transform:uppercase; letter-spacing:.07em; padding:3px 8px; border-radius:4px; margin-bottom:10px; }
.vv-question { font-size:.95rem; font-weight:600; color:#1f2937; margin-bottom:6px; }
.vv-how { font-size:.875rem; color:#6b7280; line-height:1.6; }
h3 { font-size:1rem; font-weight:700; color:#1f2937; margin:24px 0 10px; } h3:first-child{ margin-top:0; }
p { font-size:.9rem; color:#6b7280; line-height:1.7; margin-bottom:12px; } strong { color:#1f2937; }

/* quiz */
.quiz-block-wrapper { padding:40px 40px 44px; background:#fff; }
.quiz-header { display:flex; align-items:center; gap:14px; margin-bottom:24px; max-width:720px; margin-left:auto; margin-right:auto; width:100%; }
.quiz-icon-box { width:44px; height:44px; background:#eef2ff; border:1.5px solid #c7d2fe; border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:20px; }
.quiz-header-text h2 { font-size:1.2rem; font-weight:700; color:#1f2937; margin-bottom:2px; }
.quiz-header-text p { font-size:.83rem; color:#9ca3af; margin:0; }
.carousel-container { position:relative; overflow:hidden; max-width:720px; margin:0 auto; width:100%; }
.carousel-track { display:flex; transition:transform .42s cubic-bezier(.4,0,.2,1); }
.carousel-slide { min-width:100%; padding:0 2px; }
.question-card { background:#fff; border:1.5px solid #e5e7eb; border-radius:14px; padding:28px 28px 22px; box-shadow:0 2px 12px rgba(0,0,0,.05); }
.q-progress-row { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; }
.q-dots { display:flex; gap:6px; align-items:center; }
.q-dot { width:8px; height:8px; border-radius:50%; background:#e5e7eb; transition:.25s; }
.q-dot.current { background:#3b82f6; transform:scale(1.3); } .q-dot.correct-dot{ background:#22c55e; } .q-dot.wrong-dot{ background:#f87171; } .q-dot.answered{ background:#93c5fd; }
.q-counter { font-size:.78rem; font-weight:600; color:#9ca3af; }
.question-text { font-size:.975rem; font-weight:600; color:#1f2937; line-height:1.55; margin-bottom:18px; }
.q-code { background:#0f172a; color:#e2e8f0; border-radius:8px; padding:12px 14px; font:0.82rem ui-monospace,monospace; overflow-x:auto; margin-bottom:16px; white-space:pre; }
.options-list { display:flex; flex-direction:column; gap:10px; margin-bottom:20px; }
.option-item { display:flex; align-items:flex-start; gap:12px; padding:12px 16px; border:1.5px solid #e5e7eb; border-radius:10px; cursor:pointer; transition:.15s; background:#fff; }
.option-item:hover:not(.disabled){ border-color:#93c5fd; background:#f0f9ff; }
.option-item input { width:16px; height:16px; accent-color:#3b82f6; margin-top:2px; flex-shrink:0; cursor:pointer; }
.option-label { font-size:.9rem; color:#374151; line-height:1.5; cursor:pointer; }
.option-item.selected { border-color:#3b82f6; background:#eff6ff; } .option-item.selected .option-label{ color:#1d4ed8; font-weight:500; }
.option-item.correct,.option-item.show-correct { border-color:#22c55e; background:#f0fdf4; } .option-item.correct .option-label,.option-item.show-correct .option-label{ color:#15803d; font-weight:500; }
.option-item.incorrect { border-color:#ef4444; background:#fff5f5; } .option-item.incorrect .option-label{ color:#b91c1c; font-weight:500; }
.option-item.disabled { pointer-events:none; }
.explanation { display:none; background:#f0f9ff; border-left:3px solid #3b82f6; border-radius:0 6px 6px 0; padding:12px 14px; font-size:.875rem; color:#374151; line-height:1.65; margin:4px 0 16px; }
.explanation.visible { display:block; } .explanation strong{ color:#1d4ed8; }
.result-badge { display:none; align-items:center; gap:6px; font-size:.82rem; font-weight:600; margin-bottom:14px; }
.result-badge.visible { display:flex; } .result-badge.correct-badge{ color:#15803d; } .result-badge.incorrect-badge{ color:#b91c1c; }
.question-actions { display:flex; align-items:center; justify-content:space-between; gap:10px; flex-wrap:wrap; }
.btn-show-answer { padding:8px 18px; border:1.5px solid #d1d5db; border-radius:8px; background:#fff; color:#6b7280; font:600 .875rem 'Inter'; cursor:pointer; }
.btn-show-answer:hover:not(:disabled){ border-color:#3b82f6; color:#3b82f6; background:#eff6ff; } .btn-show-answer:disabled{ opacity:.38; }
.btn-submit { padding:8px 22px; border:none; border-radius:8px; background:#3b82f6; color:#fff; font:600 .875rem 'Inter'; cursor:pointer; } .btn-submit:hover:not(:disabled){ background:#2563eb; } .btn-submit:disabled{ opacity:.38; }
.btn-next-q { padding:8px 22px; border:none; border-radius:8px; background:#1f2937; color:#fff; font:600 .875rem 'Inter'; cursor:pointer; display:none; align-items:center; gap:6px; } .btn-next-q.visible{ display:flex; } .btn-next-q:hover{ background:#374151; }

/* assessment */
.assess-q { max-width:720px; margin:0 auto 20px; background:#fff; border:1.5px solid #e5e7eb; border-radius:12px; padding:22px 24px; box-shadow:0 2px 8px rgba(0,0,0,.05); }
.assess-q .q-num { font-size:.75rem; font-weight:700; color:#0ea5e9; text-transform:uppercase; letter-spacing:.06em; }
.assess-q .q-text { font-size:.98rem; font-weight:600; color:#1f2937; margin:6px 0 12px; line-height:1.55; }
.assess-q textarea { width:100%; min-height:100px; border:1.5px solid #e5e7eb; border-radius:8px; padding:12px; font:0.9rem 'Inter'; resize:vertical; color:#374151; }
.assess-q textarea:focus { outline:none; border-color:#0ea5e9; }
.assess-actions { display:flex; justify-content:flex-end; margin-top:12px; }
.btn-model { padding:8px 18px; border:1.5px solid #0ea5e9; border-radius:8px; background:#fff; color:#0369a1; font:600 .85rem 'Inter'; cursor:pointer; }
.btn-model:hover { background:#f0f9ff; }
.model-answer { display:none; margin-top:14px; background:#f0f9ff; border-left:3px solid #0ea5e9; border-radius:0 8px 8px 0; padding:14px 16px; font-size:.88rem; color:#374151; line-height:1.7; }
.model-answer.visible { display:block; } .model-answer strong{ color:#0369a1; }

.complete-card { max-width:720px; margin:0 auto; text-align:center; padding:40px 24px; }
.complete-card h3 { font-size:1.15rem; color:#1f2937; margin-bottom:6px; } .complete-card p{ color:#6b7280; }

@media (max-width:768px){
  .header h1{ font-size:1.5rem; } .header p{ font-size:1rem; }
  .main-content{ padding-left:20px; padding-right:20px; }
  .info-grid,.pros-cons-row,.vv-grid{ grid-template-columns:1fr; }
  .continue-bar{ padding:12px 20px; } .progress-bar-wrap{ width:120px; }
  .quiz-block-wrapper{ padding:32px 20px 36px; }
}
</style>
</head>
<body>

{% for block in blocks %}
<!-- content step -->
<div class="step{% if loop.first %} active{% endif %}" data-kind="content">
  <div class="header">
    <div class="header-accent"></div>
    <div class="header-content">
      <h1>{{ block.title }}</h1>
      {% if block.subtitle %}<p>{{ block.subtitle }}</p>{% endif %}
    </div>
  </div>
  {{ block.content_html | safe }}
  {% if block.animation_html %}
  <div class="main-content">{{ block.animation_html | safe }}</div>
  {% endif %}
</div>

<!-- quiz step -->
<div class="step" data-kind="quiz" data-quiz="{{ loop.index0 }}">
  <div class="quiz-block-wrapper">
    <div class="quiz-header">
      <div class="quiz-icon-box">?</div>
      <div class="quiz-header-text">
        <h2>Quick Check</h2>
        <p>Answer all questions to continue</p>
      </div>
    </div>
    <div class="quiz-area" id="quiz-area-{{ loop.index0 }}"></div>
  </div>
</div>
{% endfor %}

{% if assessment and assessment.questions %}
<!-- assessment step -->
<div class="step" data-kind="assessment">
  <div class="header">
    <div class="header-accent assess"></div>
    <div class="header-content">
      <div class="badge">Session Assessment</div>
      <h1>Check Your Understanding</h1>
      <p>Answer in your own words, then reveal the model answer</p>
    </div>
  </div>
  <div class="main-content">
    {% for q in assessment.questions %}
    <div class="assess-q">
      <div class="q-num">Question {{ loop.index }} · {{ q.difficulty }}</div>
      <div class="q-text">{{ q.question }}</div>
      <textarea placeholder="Type your answer here…"></textarea>
      <div class="assess-actions">
        <button class="btn-model" onclick="toggleModel(this)">Show model answer</button>
      </div>
      <div class="model-answer"><strong>Model answer:</strong> {{ q.model_answer }}</div>
    </div>
    {% endfor %}
    <div class="complete-card" id="complete-card" style="display:none;">
      <h3>🎉 Session complete</h3>
      <p>You've finished {{ title }}. Review any section by scrolling up.</p>
    </div>
  </div>
</div>
{% endif %}

<div class="continue-bar">
  <div class="progress-info">
    <div class="progress-bar-wrap"><div class="progress-bar-fill" id="progress-fill" style="width:0%"></div></div>
    <span class="step-label">Step <span id="cur-step">1</span> of <span id="tot-step">1</span></span>
  </div>
  <button id="continue-btn" onclick="nextStep()">Continue
    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
  </button>
</div>

<script>
const QUIZ_DATA = {{ quiz_data | tojson }};
const steps = Array.from(document.querySelectorAll('.step'));
const TOTAL = steps.length;
let current = 0;
document.getElementById('tot-step').textContent = TOTAL;
updateProgress();

function updateProgress(){
  document.getElementById('cur-step').textContent = current + 1;
  document.getElementById('progress-fill').style.width = (((current+1)/TOTAL)*100) + '%';
}

function stepIsQuiz(el){ return el.dataset.kind === 'quiz'; }
function quizUnlocked(el){
  const area = el.querySelector('.quiz-area');
  return !area || area._allAnswered === true || area._empty === true;
}

function refreshContinue(){
  const el = steps[current];
  const btn = document.getElementById('continue-btn');
  btn.disabled = stepIsQuiz(el) && !quizUnlocked(el);
}

function nextStep(){
  const btn = document.getElementById('continue-btn');
  if (btn.disabled) return;
  if (current >= TOTAL - 1){ // finish
    btn.disabled = true; btn.innerHTML = 'Module Complete';
    const cc = document.getElementById('complete-card'); if (cc) cc.style.display = 'block';
    return;
  }
  current++;
  const el = steps[current];
  el.classList.add('active');
  updateProgress();
  if (stepIsQuiz(el)) renderQuiz(el);
  if (current === TOTAL - 1){ btn.classList.add('finish'); btn.innerHTML = 'Finish &check;'; }
  refreshContinue();
  el.scrollIntoView({ behavior:'smooth', block:'start' });
}

/* ── assessment ── */
function toggleModel(btn){
  const ma = btn.closest('.assess-q').querySelector('.model-answer');
  ma.classList.toggle('visible');
  btn.textContent = ma.classList.contains('visible') ? 'Hide model answer' : 'Show model answer';
}

/* ── MCQ carousel ── */
function renderQuiz(stepEl){
  const qi = stepEl.dataset.quiz;
  const area = stepEl.querySelector('.quiz-area');
  if (area._rendered) return; area._rendered = true;
  const questions = (QUIZ_DATA[qi] || []);
  if (questions.length === 0){ area._empty = true; area.innerHTML = '<p style="text-align:center">No questions for this section.</p>'; refreshContinue(); return; }
  const total = questions.length;
  const state = { current:0, answered:new Array(total).fill(false) };
  area._state = state;

  const esc = s => String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  const slides = questions.map((q, idx) => {
    const type = q.multi ? 'checkbox' : 'radio';
    const opts = q.options.map((o,oi)=>`<label class="option-item" id="opt-${qi}-${idx}-${oi}"><input type="${type}" name="q-${qi}-${idx}" value="${oi}"><span class="option-label">${esc(o)}</span></label>`).join('');
    const code = q.code ? `<div class="q-code">${esc(q.code)}</div>` : '';
    const last = idx === total - 1;
    return `<div class="carousel-slide"><div class="question-card">
      <div class="q-progress-row"><div class="q-dots" id="dots-${qi}-${idx}"></div><span class="q-counter">Question ${idx+1} of ${total}</span></div>
      <div class="question-text">${esc(q.question)}</div>${code}
      <div class="options-list" id="opts-${qi}-${idx}">${opts}</div>
      <div class="explanation" id="exp-${qi}-${idx}"><strong>Explanation:</strong> ${esc(q.explanation||'')}</div>
      <div class="result-badge" id="res-${qi}-${idx}"><span></span></div>
      <div class="question-actions">
        <button class="btn-show-answer" id="show-${qi}-${idx}" onclick="qShow('${qi}',${idx})">Show Answer</button>
        <div style="display:flex;gap:8px;align-items:center;">
          <button class="btn-submit" id="sub-${qi}-${idx}" onclick="qSubmit('${qi}',${idx})">Submit</button>
          <button class="btn-next-q" id="nxt-${qi}-${idx}" onclick="qNext('${qi}')">${last?'Done':'Next'}</button>
        </div>
      </div></div></div>`;
  }).join('');
  area.innerHTML = `<div class="carousel-container"><div class="carousel-track" id="track-${qi}">${slides}</div></div>`;
  questions.forEach((q,idx)=>{ qDots(qi,idx); q.options.forEach((_,oi)=>{
    const inp=document.getElementById(`opt-${qi}-${idx}-${oi}`).querySelector('input');
    inp.addEventListener('change',()=>{ const lbl=inp.closest('.option-item');
      if(q.multi){ lbl.classList.toggle('selected',inp.checked); }
      else { document.querySelectorAll(`#opts-${qi}-${idx} .option-item`).forEach(e=>e.classList.remove('selected')); lbl.classList.add('selected'); }
    });
  });});
}
function qDots(qi,active){ const s=document.getElementById('quiz-area-'+qi)._state; const el=document.getElementById(`dots-${qi}-${active}`); if(!el)return;
  el.innerHTML=Array.from({length:s.answered.length},(_,i)=>{ let c='q-dot'; if(i===s.current)c+=' current'; else if(s.results&&s.results[i]==='correct')c+=' correct-dot'; else if(s.results&&s.results[i]==='wrong')c+=' wrong-dot'; else if(s.answered[i])c+=' answered'; return `<div class="${c}"></div>`; }).join(''); }
function qLock(qi,idx,chosen,correct,mode){ document.querySelectorAll(`#opts-${qi}-${idx} .option-item`).forEach((el,oi)=>{ el.classList.add('disabled'); el.classList.remove('selected'); const i=el.querySelector('input'); if(i)i.disabled=true; if(correct.includes(oi))el.classList.add(mode==='show'?'show-correct':'correct'); if(mode!=='show'&&chosen.includes(oi)&&!correct.includes(oi))el.classList.add('incorrect'); }); }
function qSubmit(qi,idx){ const area=document.getElementById('quiz-area-'+qi); const s=area._state; const q=QUIZ_DATA[qi][idx];
  const checked=Array.from(document.querySelectorAll(`input[name="q-${qi}-${idx}"]:checked`)); if(checked.length===0){ const b=document.getElementById(`sub-${qi}-${idx}`); b.style.transform='scale(.95)'; setTimeout(()=>b.style.transform='',150); return; }
  const chosen=checked.map(e=>parseInt(e.value)); const correct=q.correctIndexes; const ok=chosen.length===correct.length&&correct.every(c=>chosen.includes(c));
  s.results=s.results||[]; s.results[idx]=ok?'correct':'wrong'; s.answered[idx]=true;
  qLock(qi,idx,chosen,correct,'submit');
  const r=document.getElementById(`res-${qi}-${idx}`); r.className='result-badge visible '+(ok?'correct-badge':'incorrect-badge'); r.querySelector('span').textContent=ok?'Correct':'Incorrect — see the explanation below.';
  document.getElementById(`exp-${qi}-${idx}`).classList.add('visible');
  document.getElementById(`show-${qi}-${idx}`).disabled=true; document.getElementById(`sub-${qi}-${idx}`).disabled=true; document.getElementById(`nxt-${qi}-${idx}`).classList.add('visible');
  qDots(qi,idx); maybeUnlock(qi); }
function qShow(qi,idx){ const area=document.getElementById('quiz-area-'+qi); const s=area._state; const q=QUIZ_DATA[qi][idx];
  s.results=s.results||[]; s.results[idx]='shown'; s.answered[idx]=true; qLock(qi,idx,[],q.correctIndexes,'show');
  document.getElementById(`exp-${qi}-${idx}`).classList.add('visible');
  document.getElementById(`show-${qi}-${idx}`).disabled=true; document.getElementById(`sub-${qi}-${idx}`).disabled=true; document.getElementById(`nxt-${qi}-${idx}`).classList.add('visible');
  qDots(qi,idx); maybeUnlock(qi); }
function qNext(qi){ const area=document.getElementById('quiz-area-'+qi); const s=area._state; if(s.current<s.answered.length-1){ s.current++; document.getElementById('track-'+qi).style.transform=`translateX(-${s.current*100}%)`; setTimeout(()=>qDots(qi,s.current),50); } }
function maybeUnlock(qi){ const area=document.getElementById('quiz-area-'+qi); const s=area._state; if(s.answered.every(Boolean)){ area._allAnswered=true; refreshContinue(); } }

refreshContinue();
</script>
</body>
</html>
